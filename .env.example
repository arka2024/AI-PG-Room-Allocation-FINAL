# CohabitAI Configuration
# Copy this file to .env and fill in your actual values

# ═══════════════════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════════════════

# Local JSON file path (default: local_data/)
# USERS_FILE=local_data/users_local_balanced.json

# ═══════════════════════════════════════════════════════════
# Gemma 3B Question Generation (Local - Recommended)
# ═══════════════════════════════════════════════════════════

# Ollama server URL (for local Gemma 3B)
# Install: https://ollama.ai
# Run: ollama pull gemma3:4b
OLLAMA_URL=http://localhost:11434/api/generate
GEMMA_MODEL=gemma3:4b

# ═══════════════════════════════════════════════════════════
# Gemma 3B Question Generation (Google API)
# ═══════════════════════════════════════════════════════════

# Google Gemini API Key (alternative to Ollama)
# Get from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your-api-key-here
# GEMINI_MODEL=gemma-3-4b-it

# ═══════════════════════════════════════════════════════════
# Admin Access
# ═══════════════════════════════════════════════════════════

# Comma-separated list of admin emails for question regeneration
ADMIN_EMAILS=admin@example.com,dev@example.com

# ═══════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=1

# Session secret (change in production)
SECRET_KEY=cohabitai-dev-secret-2026

# ═══════════════════════════════════════════════════════════
# Optional: MongoDB (if switching from local JSON)
# ═══════════════════════════════════════════════════════════

# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cohabitai
